# --- Registration (optional) ------------------------------------------------
# The stats pages work with NO backend at all — they read straight from the
# OpenFront public API. These two vars are only needed if you want the
# Discord-gated registration flow (members entering in-game name / timezone /
# OpenFront public id) to persist to a real backend.
#
# Create a free Supabase project, enable the Discord auth provider, run
# supabase/schema.sql, then fill these in. Leave them blank to run the site
# without registration (a "coming soon" note is shown on /register instead).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
