{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/vendor"
  ],
  "references": [
    {
      "path": "./src/vendor/openfront-core"
    },
    {
      "path": "./src/vendor/openfront-core-aeb8d60"
    },
    {
      "path": "./src/vendor/openfront-core-16be9d7"
    },
    {
      "path": "./src/vendor/openfront-core-fe5d770"
    },
    {
      "path": "./src/vendor/openfront-core-53e1a5b"
    },
    {
      "path": "./src/vendor/openfront-core-f0da418"
    }
  ]
}
